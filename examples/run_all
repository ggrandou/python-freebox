#!/usr/bin/env bash
# Run all examples/test_* integration scripts against a real Freebox.
#
# Usage:
#   examples/run_all [freebox_host]
#
# Each script is run in sequence. Failures are collected and reported at the
# end; a failing script does not stop the run.

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
HOST=${1:-mafreebox.freebox.fr}

PASS=0
FAIL=0
FAILURES=()

run() {
    local name=$1
    printf '\n%s\n' "━━━  $name  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    if "$SCRIPT_DIR/$name" "$HOST"; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        FAILURES+=("$name")
    fi
}

for script in "$SCRIPT_DIR"/test_*; do
    run "$(basename "$script")"
done

printf '\n%s\n' "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
printf 'Results: %d passed, %d failed\n' "$PASS" "$FAIL"

if [ "${#FAILURES[@]}" -gt 0 ]; then
    printf 'Failed scripts:\n'
    for f in "${FAILURES[@]}"; do
        printf '  - %s\n' "$f"
    done
    exit 1
fi
