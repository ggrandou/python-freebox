#!/usr/bin/env python3
"""Test the call log and voicemail API against a real Freebox.

Usage:
    tools/test_call [freebox_host]

Credentials are loaded via CredentialStore (app_id fr.freebox.python_test).
"""
from __future__ import annotations

import datetime
import sys

from freebox import CredentialStore, Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
STORE = CredentialStore("fr.freebox.python_test")


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<18} {value}")


def fmt_ts(ts: int) -> str:
    if not ts:
        return "(none)"
    return datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M:%S")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        store=STORE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("Phone account")
    try:
        account = fb.call.account()
        row("phone_number", account.phone_number or "(none)")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Call log")
    try:
        entries = fb.call.list()
        if not entries:
            print("  (none)")
        for e in entries[:5]:
            print(f"\n  [{e.id}] {e.type}")
            row("number", e.number or "(unknown)")
            row("name", e.name or "(unknown)")
            row("datetime", fmt_ts(e.datetime))
            row("duration", f"{e.duration}s")
            row("new", e.new)
        if len(entries) > 5:
            print(f"\n  … {len(entries) - 5} more entries")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Voicemails")
    try:
        vms = fb.call.voicemails()
        if not vms:
            print("  (none)")
        for vm in vms:
            print(f"\n  [{vm.id}]")
            row("phone_number", vm.phone_number or "(unknown)")
            row("country_code", vm.country_code or "(none)")
            row("date", fmt_ts(vm.date))
            row("duration", f"{vm.duration}s")
            row("read", vm.read)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
