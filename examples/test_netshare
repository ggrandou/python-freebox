#!/usr/bin/env python3
"""Test the Network Share (Samba / AFP) API against a real Freebox.

Usage:
    tools/test_netshare [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<24} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("Samba configuration")
    try:
        s = fb.netshare.samba()
        row("file_share_enabled", s.file_share_enabled)
        row("print_share_enabled", s.print_share_enabled)
        row("logon_enabled", s.logon_enabled)
        row("logon_user", s.logon_user or "(none)")
        row("workgroup", s.workgroup or "(none)")
        row("smbv2_enabled", s.smbv2_enabled)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("AFP configuration")
    try:
        a = fb.netshare.afp()
        row("enabled", a.enabled)
        row("guest_allow", a.guest_allow)
        row("login_name", a.login_name or "(none)")
        row("server_type", a.server_type or "(none)")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
