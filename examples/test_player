#!/usr/bin/env python3
"""Test the Player API against a real Freebox.

Usage:
    tools/test_player [freebox_host]

Only read-only operations are performed.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("Players")
    try:
        players = fb.player.players()
        if not players:
            print("  (none)")
        for p in players:
            row(
                f"player {p.id}",
                f"name={p.device_name!r}  reachable={p.reachable}"
                f"  api_available={p.api_available}",
            )
            if p.api_available:
                try:
                    status = fb.player.status(p.id)
                    row(f"  status", f"power_state={status.power_state}")
                    vol = fb.player.volume(p.id)
                    row(f"  volume", f"volume={vol.volume}  mute={vol.mute}")
                except FreeboxError as e:
                    row(f"  status", f"(unavailable: {e})")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
