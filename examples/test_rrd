#!/usr/bin/env python3
"""Report RRD stats from the Freebox.

Usage:
    tools/test_rrd [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox, RRDDatabase
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def show_db(fb: Freebox, db: RRDDatabase, name: str) -> None:
    section(name)
    try:
        r = fb.rrd.fetch(db)
        row("date_start", r.date_start)
        row("date_end", r.date_end)
        row("samples", len(r.data))
        if r.data:
            last = r.data[-1]
            row("last sample time", last.time)
            for field, value in last.values.items():
                row(f"  {field}", value)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    show_db(fb, RRDDatabase.NET, "Network stats (net)")
    show_db(fb, RRDDatabase.TEMP, "Temperature stats (temp)")
    show_db(fb, RRDDatabase.DSL, "DSL stats (dsl)")
    show_db(fb, RRDDatabase.SWITCH, "Switch stats (switch)")

    fb.close()
    print()


if __name__ == "__main__":
    main()
