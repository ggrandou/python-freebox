#!/usr/bin/env python3
"""Report current Freebox SFP port status and configuration.

Usage:
    tools/test_sfp [freebox_host]

Credentials are loaded via CredentialStore (app_id fr.freebox.python_test).
"""
from __future__ import annotations

import sys

from freebox import CredentialStore, Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
STORE = CredentialStore("fr.freebox.python_test")


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        store=STORE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    # ── SFP status ─────────────────────────────────────────────────────────────
    section("SFP Status")
    try:
        s = fb.sfp.status()
        row("present", s.present)
        row("eeprom_valid", s.eeprom_valid)
        row("supported", s.supported)
        row("type", s.type or "—")
        row("power_good", s.power_good)
        row("link", s.link)
        row("vendor_name", s.vendor_name or "—")
        row("part_number", s.part_number or "—")
        row("hardware_rev", s.hardware_rev or "—")
        row("serial_number", s.serial_number or "—")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── SFP config ─────────────────────────────────────────────────────────────
    section("SFP Configuration")
    try:
        c = fb.sfp.config()
        row("sfp_type_forced", c.sfp_type_forced)
        row("sfp_type_forced_value", c.sfp_type_forced_value or "—")
        row("available_sfp_types", ", ".join(c.available_sfp_types) or "—")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
