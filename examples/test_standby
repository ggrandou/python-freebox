#!/usr/bin/env python3
"""Test the Standby API against a real Freebox.

Usage:
    tools/test_standby [freebox_host]

Only read-only operations are performed.
"""
from __future__ import annotations

import sys

from freebox import CredentialStore, Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
STORE = CredentialStore("fr.freebox.python_test")


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        store=STORE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("Standby status")
    try:
        status = fb.standby.status()
        row("use_planning", status.use_planning)
        row("planning_mode", status.planning_mode)
        row("next_change", status.next_change)
        row("available_modes", status.available_planning_modes)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Standby config")
    try:
        cfg = fb.standby.config()
        row("use_planning", cfg.use_planning)
        row("planning_mode", cfg.planning_mode)
        row("resolution", cfg.resolution)
        row("mapping slots", len(cfg.mapping))
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
