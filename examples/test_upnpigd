#!/usr/bin/env python3
"""Test the UPnP IGD API against a real Freebox.

Usage:
    tools/test_upnpigd [freebox_host]

Credentials are loaded via CredentialStore (app_id fr.freebox.python_test).
"""
from __future__ import annotations

import sys

from freebox import CredentialStore, Freebox, UpnpIgd
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
STORE = CredentialStore("fr.freebox.python_test")


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        store=STORE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    igd: UpnpIgd = fb.upnpigd

    section("UPnP IGD configuration")
    try:
        cfg = igd.config()
        row("enabled", cfg.enabled)
        row("version", cfg.version)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Active UPnP IGD redirections")
    try:
        redirs = igd.redirs()
        if not redirs:
            print("  (none)")
        for r in redirs:
            print(f"\n  [{r.id}]")
            row("proto", r.proto)
            row("ext_src_ip", r.ext_src_ip)
            row("ext_port", r.ext_port)
            row("int_ip", r.int_ip)
            row("int_port", r.int_port)
            row("desc", r.desc or "(none)")
            row("remaining", f"{r.remaining}s" if r.remaining else "no expiry")
            row("enabled", r.enabled)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
