#!/usr/bin/env python3
"""Test the Virtual Machine API against a real Freebox.

Usage:
    tools/test_vm [freebox_host]

Credentials are loaded via CredentialStore (app_id fr.freebox.python_test).
Only read-only operations are performed.
"""
from __future__ import annotations

import sys

from freebox import CredentialStore, Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
STORE = CredentialStore("fr.freebox.python_test")


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<24} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        store=STORE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("VM system info")
    try:
        info = fb.vm.info()
        row("total_memory (MB)", info.total_memory)
        row("used_memory  (MB)", info.used_memory)
        row("total_cpus", info.total_cpus)
        row("used_cpus", info.used_cpus)
        row("usb_ports", info.usb_ports)
        row("usb_used", info.usb_used)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("VM distributions")
    try:
        distros = fb.vm.distros()
        if not distros:
            print("  (none)")
        for dist in distros:
            print(f"\n  {dist.name!r}  [{dist.os}]")
            row("url", dist.url)
            row("hash", dist.hash)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Virtual machines")
    try:
        vms = fb.vm.list()
        if not vms:
            print("  (none)")
        for vm in vms:
            print(f"\n  [{vm.id}] {vm.name!r}  status={vm.status}")
            row("disk_path", vm.disk_path_decoded)
            row("disk_type", vm.disk_type)
            row("cd_path", vm.cd_path_decoded or "(none)")
            row("memory (MB)", vm.memory)
            row("vcpus", vm.vcpus)
            row("mac", vm.mac)
            row("os", vm.os)
            row("enable_screen", vm.enable_screen)
            row("bind_usb_ports", vm.bind_usb_ports or "(none)")
            row("enable_cloudinit", vm.enable_cloudinit)
            if vm.enable_cloudinit:
                row("cloudinit_hostname", vm.cloudinit_hostname)

            print(f"  console_url  : {fb.vm.console_url(vm.id)}")
            if vm.enable_screen:
                print(f"  vnc_url      : {fb.vm.vnc_url(vm.id)}")

            if vm.disk_path:
                try:
                    di = fb.vm.disk_info(vm.disk_path)
                    row("disk.type", di.type)
                    row("disk.actual_size", di.actual_size)
                    row("disk.virtual_size", di.virtual_size)
                except FreeboxError as e:
                    print(f"  (disk_info unavailable: {e})")

            vm2 = fb.vm.get(vm.id)
            assert vm2.id == vm.id
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
