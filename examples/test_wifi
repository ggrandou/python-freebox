#!/usr/bin/env python3
"""Report current Freebox Wi-Fi status and configuration.

Usage:
    tools/test_wifi [freebox_host]

Credentials are loaded via CredentialStore (app_id fr.freebox.python_test).
"""
from __future__ import annotations

import sys

from freebox import CredentialStore, Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
STORE = CredentialStore("fr.freebox.python_test")


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<32} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        store=STORE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    # ── Global config ──────────────────────────────────────────────────────────
    section("Wi-Fi global config")
    try:
        cfg = fb.wifi.config()
        row("enabled", cfg.enabled)
        row("mac_filter_state", cfg.mac_filter_state)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Steering config ────────────────────────────────────────────────────────
    section("Wi-Fi steering config")
    try:
        sc = fb.wifi.steering_config()
        row("steering_level", sc.steering_level)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Global state ───────────────────────────────────────────────────────────
    section("Wi-Fi global state")
    try:
        s = fb.wifi.state()
        row("state", s.state)
        row("power_saving_capability", s.power_saving_capability)
        for phy in s.expected_phys:
            row(f"  phy {phy.phy_id} ({phy.band})", "detected" if phy.detected else "missing")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Access Points ──────────────────────────────────────────────────────────
    section("Wi-Fi access points")
    try:
        aps = fb.wifi.aps()
    except FreeboxError as e:
        print(f"  (unavailable: {e})")
        fb.close()
        return

    for ap in aps:
        state = ap.status.state if ap.status else "?"
        band  = ap.config.band if ap.config else "?"
        ch    = ap.status.primary_channel if ap.status else "?"
        row(f"AP {ap.id} ({ap.name})", f"state={state}  band={band}  channel={ch}")

    # ── Per-AP details ─────────────────────────────────────────────────────────
    for ap in aps:
        section(f"AP {ap.id} stations")
        try:
            stations = fb.wifi.ap_stations(ap.id)
            if not stations:
                print("  (no stations)")
            for s in stations:
                row(s.mac, f"hostname={s.hostname or '?'}  signal={s.signal} dB  state={s.state}")
        except FreeboxError as e:
            print(f"  (unavailable: {e})")

        section(f"AP {ap.id} neighbors")
        try:
            neighbors = fb.wifi.ap_neighbors(ap.id)
            if not neighbors:
                print("  (no neighbors)")
            for n in sorted(neighbors, key=lambda x: x.signal, reverse=True)[:5]:
                row(n.bssid, f"ssid={n.ssid!r}  band={n.band}  ch={n.channel}  signal={n.signal} dB")
        except FreeboxError as e:
            print(f"  (unavailable: {e})")

        section(f"AP {ap.id} channel usage")
        try:
            usage = fb.wifi.ap_channel_usage(ap.id)
            for u in sorted(usage, key=lambda x: x.channel)[:5]:
                row(f"ch {u.channel} ({u.band})", f"noise={u.noise_level} dB  busy={u.rx_busy_percent}%")
        except FreeboxError as e:
            print(f"  (unavailable: {e})")

    # ── BSS ────────────────────────────────────────────────────────────────────
    section("Wi-Fi BSS")
    try:
        for b in fb.wifi.bss_list():
            ssid  = b.config.ssid if b.config else "?"
            state = b.status.state if b.status else "?"
            stas  = b.status.sta_count if b.status else "?"
            row(b.id, f"ssid={ssid!r}  state={state}  stations={stas}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Planning ───────────────────────────────────────────────────────────────
    section("Wi-Fi planning")
    try:
        p = fb.wifi.planning()
        row("use_planning", p.use_planning)
        row("resolution", p.resolution)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── MAC filters ────────────────────────────────────────────────────────────
    section("Wi-Fi MAC filters")
    try:
        filters = fb.wifi.mac_filters()
        if not filters:
            print("  (no filters)")
        for f in filters:
            row(f.mac, f"type={f.type}  comment={f.comment!r}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Global diagnostics ─────────────────────────────────────────────────────
    section("Wi-Fi diagnostics")
    try:
        d = fb.wifi.diag()
        if not d.aps and not d.bsss:
            print("  (no issues)")
        for item in d.aps:
            print(f"  AP {item.ap_id}: [{item.severity}] {item.code}")
        for item in d.bsss:
            print(f"  BSS {item.bssid}: [{item.severity}] {item.code}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── WPS ────────────────────────────────────────────────────────────────────
    section("WPS config")
    try:
        wps = fb.wifi.wps_config()
        row("enabled", wps.enabled)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("WPS sessions")
    try:
        sessions = fb.wifi.wps_sessions()
        if not sessions:
            print("  (no sessions)")
        for s in sessions:
            row(f"session {s.id}", f"ssid={s.ssid!r}  active={s.active}  result={s.result}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Guest Wi-Fi (custom keys) ───────────────────────────────────────────────
    section("Guest Wi-Fi config")
    try:
        cfg = fb.wifi.custom_keys_config()
        row("ssid", cfg.ssid)
        row("ssid_read_only", cfg.ssid_read_only)
        row("hide_ssid", cfg.hide_ssid)
        row("encryption", cfg.encryption)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Guest Wi-Fi custom keys")
    try:
        keys = fb.wifi.custom_keys()
        if not keys:
            print("  (no keys)")
        for k in keys:
            desc = k.params.description if k.params else "?"
            row(f"key {k.id}", f"desc={desc!r}  remaining={k.remaining}s")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Temporary disable ──────────────────────────────────────────────────────
    section("Temporary Wi-Fi disable")
    try:
        remaining = fb.wifi.temp_disable_state()
        if remaining:
            print(f"  active — {remaining}s remaining")
        else:
            print("  inactive")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── BSS MLO ────────────────────────────────────────────────────────────────
    section("BSS MLO configuration")
    try:
        for b in fb.wifi.bss_list():
            try:
                mlo = fb.wifi.bss_mlo_config(b.id)
                combs = fb.wifi.bss_mlo_allowed_combs(b.id)
                row(b.id, f"partners={mlo.partners}  allowed={combs}")
            except FreeboxError:
                pass
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
