#!/usr/bin/env python3
"""Test the Freeplug (CPL) API against a real Freebox.

Usage:
    tools/test_freeplug [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<24} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("Freeplug networks")
    try:
        networks = fb.freeplug.networks()
        if not networks:
            print("  (no Freeplug network detected)")
        for net in networks:
            print(f"\n  Network [{net.id}]  ({len(net.members)} member(s))")
            for node in net.members:
                print(f"\n    [{node.id}]")
                row("net_role", node.net_role)
                row("model", node.model)
                row("local", node.local)
                row("has_network", node.has_network)
                row("eth_port_status", node.eth_port_status)
                row("eth_speed", f"{node.eth_speed} Mbps")
                row("eth_full_duplex", node.eth_full_duplex)
                row("rx_rate", f"{node.rx_rate} Mb/s" if node.rx_rate >= 0 else "n/a")
                row("tx_rate", f"{node.tx_rate} Mb/s" if node.tx_rate >= 0 else "n/a")
                row("inactive", f"{node.inactive}s")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
