#!/usr/bin/env python3
"""Test the FTP server API against a real Freebox.

Usage:
    tools/test_ftp [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("FTP server configuration")
    try:
        cfg = fb.ftp.config()
        row("enabled", cfg.enabled)
        row("allow_anonymous", cfg.allow_anonymous)
        row("allow_anonymous_write", cfg.allow_anonymous_write)
        row("allow_remote_access", cfg.allow_remote_access)
        row("weak_password", cfg.weak_password)
        row("port_ctrl", cfg.port_ctrl)
        row("port_data", cfg.port_data)
        row("username", cfg.username or "(none)")
        row("remote_domain", cfg.remote_domain or "(none)")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
