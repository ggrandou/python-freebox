#!/usr/bin/env python3
"""Report current Freebox LAN status and browser information.

Usage:
    tools/test_lan [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import datetime
import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def fmt_ts(ts: int) -> str:
    if not ts:
        return "—"
    return datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M:%S")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    lan = fb.lan

    # ── LAN config ─────────────────────────────────────────────────────────────
    section("LAN Configuration")
    try:
        c = lan.config()
        row("IP", c.ip)
        row("mode", c.mode)
        row("name", c.name)
        row("DNS name", c.name_dns)
        row("mDNS name", c.name_mdns)
        row("NetBIOS name", c.name_netbios)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Static routes ──────────────────────────────────────────────────────────
    section("Static Routes")
    try:
        routes = lan.routes()
        if not routes:
            print("  (no static routes)")
        for r in routes:
            enabled = "enabled" if r.enabled else "disabled"
            desc = f"  [{r.description}]" if r.description else ""
            print(f"  {r.prefix:<22} → {r.gateway:<16} {enabled}{desc}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── LAN interfaces ─────────────────────────────────────────────────────────
    section("LAN Interfaces")
    try:
        ifaces = lan.interfaces()
        if not ifaces:
            print("  (no interfaces)")
        for iface in ifaces:
            print(f"  {iface.name:<16} {iface.host_count} host(s)")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")
        ifaces = []

    # ── Host types ─────────────────────────────────────────────────────────────
    section("Available Host Types")
    try:
        types = lan.host_types()
        for t in types:
            cat = f"  [{t.category}]" if t.category else ""
            print(f"  {t.type:<24} {t.name}{cat}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    # ── Hosts per interface ────────────────────────────────────────────────────
    first_host_fetched = False
    for iface in ifaces:
        section(f"Hosts on '{iface.name}'")
        try:
            hosts = lan.hosts(iface.name)
            if not hosts:
                print("  (no hosts)")
                continue
            if not first_host_fetched:
                h0 = lan.host(iface.name, hosts[0].id)
                assert h0.id == hosts[0].id
                first_host_fetched = True
            for h in hosts:
                status = "●" if h.reachable else "○"
                active = " active" if h.active else ""
                persistent = " persistent" if h.persistent else ""
                print(f"\n  {status} {h.primary_name or h.id}")
                row("  id", h.id)
                row("  host type", h.host_type)
                row("  primary name manual", h.primary_name_manual)
                if h.domain_name:
                    row("  domain name", h.domain_name)
                if h.vendor_name:
                    row("  vendor", h.vendor_name)
                row("  reachable", h.reachable)
                row("  active", str(h.active) + active)
                row("  persistent", str(h.persistent) + persistent)
                row("  last seen", fmt_ts(h.last_time_reachable))
                row("  last activity", fmt_ts(h.last_activity))
                if h.first_activity:
                    row("  first activity", fmt_ts(h.first_activity))
                if h.l2ident:
                    for l2 in h.l2ident:
                        row(f"  L2 ({l2.type})", l2.id)
                if h.names:
                    for n in h.names:
                        row(f"  name ({n.source})", n.name)
                for l3 in h.l3connectivities:
                    reachable = "reachable" if l3.reachable else "unreachable"
                    act = " active" if l3.active else ""
                    row(f"  L3 {l3.af}", f"{l3.addr}  {reachable}{act}")
                if h.network_control:
                    nc = h.network_control
                    row("  network control", f"profile={nc.profile_id} name={nc.name!r} mode={nc.current_mode}")
                if h.info:
                    row("  info sources", ", ".join(h.info.keys()))
        except FreeboxError as e:
            print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
