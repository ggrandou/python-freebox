#!/usr/bin/env python3
"""Test the LED strip API against a real Freebox.

Usage:
    tools/test_ledstrip [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import datetime
import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<24} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("LED strip status")
    try:
        s = fb.ledstrip.status()
        row("use_planning", s.use_planning)
        if s.next_change:
            ts = datetime.datetime.fromtimestamp(s.next_change / 1000)
            row("next_change", ts.strftime("%Y-%m-%d %H:%M:%S"))
        else:
            row("next_change", "none")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("LED strip planning")
    try:
        p = fb.ledstrip.planning()
        row("use_planning", p.use_planning)
        row("planning_mode", p.planning_mode)
        row("resolution", p.resolution)
        slot_minutes = (60 * 24) // p.resolution if p.resolution else 0
        row("slot duration", f"{slot_minutes} min")
        active = sum(1 for v in p.mapping if v)
        row("disabled slots", f"{active} / {len(p.mapping)}")
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
