#!/usr/bin/env python3
"""Test the PVR (TV Recording) API against a real Freebox.

Usage:
    tools/test_pvr [freebox_host]

Only read-only operations are performed.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    section("PVR config")
    try:
        cfg = fb.pvr.config()
        row("margin_before", cfg.margin_before)
        row("margin_after", cfg.margin_after)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("PVR quota")
    try:
        quota = fb.pvr.quota()
        row("quota_exceeded", quota.quota_exceeded)
        row("needed_tresh", quota.needed_tresh)
        row("cur_tresh", quota.cur_tresh)
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Programmed records")
    try:
        records = fb.pvr.programmed()
        if not records:
            print("  (none)")
        for r in records:
            row(
                f"precord {r.id}",
                f"name={r.name!r}  channel={r.channel_name}"
                f"  state={r.state}  conflict={r.conflict}",
            )
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Finished records")
    try:
        records = fb.pvr.finished()
        if not records:
            print("  (none)")
        for r in records:
            row(
                f"frecord {r.id}",
                f"name={r.name!r}  channel={r.channel_name}"
                f"  size={r.byte_size}  state={r.state}",
            )
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    section("Storage media")
    try:
        media = fb.pvr.media()
        if not media:
            print("  (none)")
        for m in media:
            row(
                f"media {m.media!r}",
                f"free={m.free_bytes}  total={m.total_bytes}",
            )
    except FreeboxError as e:
        print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
