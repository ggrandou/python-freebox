#!/usr/bin/env python3
"""Report current Freebox switch port status and statistics.

Usage:
    tools/test_switch [freebox_host]

The app token is stored in .freebox_test_token between runs.
"""
from __future__ import annotations

import sys
from pathlib import Path

from freebox import Freebox
from freebox.exceptions import FreeboxError

HOST = sys.argv[1] if len(sys.argv) > 1 else "mafreebox.freebox.fr"
TOKEN_FILE = Path(__file__).parent.parent / ".freebox_test_token"


def section(title: str) -> None:
    print(f"\n── {title} {'─' * (50 - len(title))}")


def row(label: str, value: object) -> None:
    print(f"  {label:<28} {value}")


def main() -> None:
    print(f"Connecting to {HOST} …")

    fb = Freebox(
        app_id="fr.freebox.python_test",
        app_name="python-freebox test",
        app_version="0.1",
        device_name="test-client",
        host=HOST,
        token_file=TOKEN_FILE,
    )
    fb.open()

    d = fb.discovery
    print(f"  device  : {d.device_name}  ({d.box_model_name})")
    print(f"  API     : v{d.api_major_version}")

    # ── Switch port status ─────────────────────────────────────────────────────
    section("Switch port status")
    try:
        ports = fb.switch.status()
    except FreeboxError as e:
        print(f"  (unavailable: {e})")
        fb.close()
        return

    for p in sorted(ports, key=lambda x: x.id):
        hosts = ", ".join(f"{m.hostname or m.mac}" for m in p.mac_list) if p.mac_list else "—"
        row(f"port {p.id}", f"link={p.link:<4}  mode={p.mode:<14}  hosts={hosts}")

    # ── Per-port config and stats ──────────────────────────────────────────────
    for p in sorted(ports, key=lambda x: x.id):
        section(f"Port {p.id} config")
        try:
            cfg = fb.switch.port_config(p.id)
            row("speed", cfg.speed)
            row("duplex", cfg.duplex)
        except FreeboxError as e:
            print(f"  (unavailable: {e})")
            continue

        if p.link == "up":
            section(f"Port {p.id} stats")
            try:
                s = fb.switch.port_stats(p.id)
                row("rx_good_bytes", s.rx_good_bytes)
                row("rx_bytes_rate", f"{s.rx_bytes_rate} B/s")
                row("rx_packets_rate", f"{s.rx_packets_rate} pkt/s")
                row("tx_bytes", s.tx_bytes)
                row("tx_bytes_rate", f"{s.tx_bytes_rate} B/s")
                row("tx_packets_rate", f"{s.tx_packets_rate} pkt/s")
                row("tx_collisions", s.tx_collisions)
            except FreeboxError as e:
                print(f"  (unavailable: {e})")

    fb.close()
    print()


if __name__ == "__main__":
    main()
